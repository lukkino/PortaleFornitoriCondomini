# frontend/.env.example
# Copia questo file in frontend/.env per lo sviluppo locale (mai committare .env)

# URL del backend. In locale il proxy di Vite (vite.config.js) instrada già
# /api verso http://localhost:8000, quindi questa variabile serve solo
# quando punti a un backend diverso (es. produzione, staging).
VITE_API_URL=http://localhost:8000
