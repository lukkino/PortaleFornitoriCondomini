# backend/.env.example
# Copia questo file in backend/.env e compila i valori (mai committare .env)

# Database PostgreSQL (Supabase) — prendi la connection string da:
# Supabase > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT — genera una chiave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — origini permesse separate da virgola
ALLOWED_ORIGINS=http://localhost:5173